# WorkHere Korea demo environment
#
# 현재 MVP는 외부 API 없이 mock/static 데이터로 동작하므로 필수 환경변수는 없습니다.
# 아래 값들은 향후 지도 API, 분석 이벤트, 백엔드 연결을 붙일 때 사용할 자리입니다.

# 데모 모드 표시 및 mock/fallback 사용 여부
VITE_DEMO_MODE=true

# 외부 공유 URL을 앱 내부에서 표시하거나 분석 이벤트에 남길 때 사용합니다.
# 예: https://example.ngrok-free.app 또는 https://workhere-korea.vercel.app
VITE_PUBLIC_BASE_URL=

# 지도 API는 현재 사용하지 않습니다. 실지도 연동 시에만 설정합니다.
VITE_MAP_PROVIDER=static
VITE_MAP_API_KEY=

# 분석 이벤트 전송 endpoint는 현재 mock입니다.
VITE_ANALYTICS_ENDPOINT=
